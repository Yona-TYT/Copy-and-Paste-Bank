<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"

        android:text="Valor de Tasa"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"

        android:text="Tasa:"
        android:textSize="@dimen/inner_text_1"
        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="1dp">
        <TextView
            android:id="@+id/vt_tasa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="6dp"
            android:textSize="@dimen/inner_text_2"
            android:text="0"
            android:textStyle="bold" />

        <Button
            android:id="@+id/butt1"
            android:layout_width="@dimen/button_ws"
            android:layout_height="@dimen/button_h1"
            android:minWidth="100dp"
            android:padding="2dp"
            android:layout_marginLeft="40dp"


            android:text="Copiar"

            android:textSize="@dimen/inner_text_1"
            app:layout_constraintEnd_toStartOf="@+id/guideline"
            app:layout_constraintHorizontal_bias="0.450"
            app:layout_constraintStart_toEndOf="@+id/text1"
            app:layout_constraintTop_toBottomOf="@+id/butt1" />


    </LinearLayout>

    <TextView
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"

        android:text="Dolares:"
        android:textSize="@dimen/inner_text_1"
        />

    <com.example.copy_paste_bank.CurrencyEditText
        android:id="@+id/et_tasa_dol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:focusable="true"
        android:imeOptions="actionDone"
        android:maxLength="20"
        android:padding="6dp"

        android:textSize="@dimen/inner_text_2"
        android:hint="Ingrese Dolares"

        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/guideline2"
        app:layout_constraintTop_toBottomOf="@+id/textV6"

        app:localeTag="ES"
        app:maxNumberOfDecimalDigits="2"
        app:currencySymbol="$"
        app:currencySymbolSuffix="true"
        tools:ignore="MissingConstraints" />

    <TextView
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"

        android:text="Bolivares:"
        android:textSize="@dimen/inner_text_1"
        />

    <com.example.copy_paste_bank.CurrencyEditText
        android:id="@+id/et_tasa_bs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:focusable="true"
        android:imeOptions="actionDone"
        android:maxLength="20"
        android:padding="6dp"

        android:textSize="@dimen/inner_text_2"
        android:hint="Ingrese Bolivares"

        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/guideline2"
        app:layout_constraintTop_toBottomOf="@+id/textV6"

        app:localeTag="ES"
        app:maxNumberOfDecimalDigits="2"
        app:currencySymbol="Bs"
        app:currencySymbolSuffix="true"
        tools:ignore="MissingConstraints" />



</LinearLayout>